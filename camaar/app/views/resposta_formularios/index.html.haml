= stylesheet_link_tag "resposta_formulario.css"

.lista-respostas
  - if @formularios&.any?
    - @formularios.each do |form|
      = link_to resposta_formulario_path(form.id), data: { nome: form.turma.disciplina.nome } do
        .card
          %div
            %p.texto-destaque= form.turma.disciplina.nome
            %p.semestre= form.turma.semestre
          %p.texto-destaque= form.turma.nome_professor
  - else
    %p Nenhum formulário respondido!