.container-templates
  - @templates.each do |template|
    .template-card{ 'data-nome' => template.nome.to_s.strip.squish }
      .template-info
        %strong= template.nome
        %br
        %span.semestre= template.data_versao&.strftime('%Y.%m') || 'semestre'
      .template-actions
        = link_to edit_template_path(template), class: 'btn-editar', title: 'Editar' do
          %i.icon{ 'data-nome' => 'Editar Template' } ✏️
        = button_to '🗑️', template_path(template), method: :delete, form: { style: 'display:inline;' }, title: 'Deletar'
  %button.add-template-card{ 
    type: "button", 
    onclick: "window.location='#{new_template_path}'", 
    'aria-label' => 'Adicionar template', 
    id: "add-template-btn",
    'data-nome' => 'Adicionar template'
  }
    +
    %span.visually-hidden Adicionar template

:css
  body {
    background: #ddd;
  }
  .container-templates {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 32px;
  }
  @media (max-width: 900px) {
    .container-templates {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 600px) {
    .container-templates {
      grid-template-columns: 1fr;
    }
  }
  .template-card, .add-template-card {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 2px 8px #0001;
    padding: 20px 24px;
    min-height: 80px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    font-family: 'Roboto', Arial, sans-serif;
  }
  .template-info {
    font-size: 1.2em;
    font-weight: bold;
    margin-bottom: 8px;
  }
  .template-actions {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    margin-top: 8px;
  }
  .template-actions button, .template-actions a {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1.1em;
    margin-left: 8px;
  }
  .add-template-card {
    min-height: 80px;
    border: 2px dashed #ccc;
    background: #fafafa;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5em;
    color: #222;
    cursor: pointer;
    transition: background 0.2s;
  }
  .add-template-card:hover {
    background: #f5f5f5;
    border-color: #999;
  }
  .visually-hidden {
    position: absolute !important;
    width: 1px !important;
    height: 1px !important;
    margin: -1px !important;
    padding: 0 !important;
    overflow: hidden !important;
    clip: rect(0, 0, 0, 0) !important;
    white-space: nowrap !important;
    border: 0 !important;
    opacity: 0 !important;
    pointer-events: none !important;
    font-size: 0 !important;
    line-height: 0 !important;
  }
